# ============================================
# ALPHA TRADING BOT - ENVIRONMENT VARIABLES
# ============================================

# Server Configuration
NODE_ENV=production
PORT=3000

# ============================================
# ⚠️ CRITICAL SECURITY: These MUST be set!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================
JWT_SECRET=your-64-character-hex-jwt-secret-here
ENCRYPTION_KEY=your-64-character-hex-encryption-key-here

# ============================================
# ⚠️ TickerAll API Key (REQUIRED for trading)
# ============================================
TICKERALL_API_KEY=your-tickerall-api-key-here

# ============================================
# ⚠️ Owner Account - Set this, then remove after first login
# ============================================
OWNER_EMAIL=admin@alpha.ai
OWNER_PASSWORD=YourSecurePasswordHere

# Optional: Force password reset on next startup
# FORCE_OWNER_PASSWORD_RESET=false

# Telegram Notifications (Optional)
TELEGRAM_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# CORS - Allowed origins
ALLOWED_ORIGINS=https://yourdomain.com

# ============================================
# Risk Management (Defaults - User can override)
# ============================================
DEFAULT_RISK_PERCENT=8
MIN_RISK_PERCENT=1
MAX_RISK_PERCENT=25
MAX_CONCURRENT_TRADES=100
MIN_BALANCE_FOR_TRADE=10
MAX_MARGIN_RISK=50
ALLOW_FORCED_TRADES=true
